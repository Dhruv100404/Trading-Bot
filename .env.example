# Required
DHAN_ACCESS_TOKEN=your_token_here
DHAN_CLIENT_ID=your_client_id_here

# Optional overrides
DHAN_BASE_URL=https://api.dhan.co/v2
DHAN_QUOTE_ENDPOINT=/marketfeed/quote
DHAN_ORDERS_ENDPOINT=/orders
DHAN_POSITIONS_ENDPOINT=/positions

# Optional Telegram trigger alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to true to log raw API responses
DEBUG=false
